---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const PHONE = '+54 294 442-6373';
const PHONE_CLEAN = '+542944426373';
const WHATSAPP_NUMBER = '5492944426373';
const WHATSAPP_MSG = encodeURIComponent('Hola! Quiero consultar disponibilidad en el hotel Argentino del Sur.');
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: t('nav.sobre'),        href: '#sobre' },
  { label: t('nav.habitaciones'), href: '#habitaciones' },
  { label: t('nav.resenas'),      href: '#resenas' },
  { label: t('nav.actividades'),  href: '#actividades' },
  { label: t('nav.ubicacion'),    href: '#ubicacion' },
  { label: t('nav.contacto'),     href: '#contacto' },
];
---

<footer class="footer" role="contentinfo">
  <!-- Top wave divider -->
  <div class="footer__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,60 L0,60 Z" fill="currentColor"/>
    </svg>
  </div>

  <div class="container">
    <div class="footer__grid">

      <!-- Brand column -->
      <div class="footer__brand">
        <a href={translatePath('/')} class="footer__logo" aria-label="Argentino del Sur - Inicio">
          <span class="footer__logo-main">Argentino del Sur</span>
          <span class="footer__logo-sub">Bariloche · Patagonia</span>
        </a>
        <p class="footer__tagline">{t('footer.tagline')}</p>

        <!-- Mini rating -->
        <div class="footer__rating">
          <span class="footer__rating-stars" aria-label="Calificación 3.5 de 5">★★★½☆</span>
          <span class="footer__rating-text">3.5 / 5 · 70 {lang === 'pt' ? 'avaliações' : 'opiniones'}</span>
        </div>

        <!-- Social-like contact chips -->
        <div class="footer__chips">
          <a href={`tel:${PHONE_CLEAN}`} class="footer__chip" aria-label={`Llamar al ${PHONE}`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.63a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            {PHONE}
          </a>
          <a href={`https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MSG}`}
             target="_blank" rel="noopener noreferrer"
             class="footer__chip footer__chip--wa" aria-label="WhatsApp">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>

      <!-- Navigation column -->
      <div class="footer__col">
        <h3 class="footer__col-title">{t('footer.nav.title')}</h3>
        <nav aria-label="Footer navigation">
          {navLinks.map(link => (
            <a href={link.href} class="footer__link">{link.label}</a>
          ))}
        </nav>
      </div>

      <!-- Contact column -->
      <div class="footer__col">
        <h3 class="footer__col-title">{t('footer.contact.title')}</h3>
        <div class="footer__contact-items">
          <div class="footer__contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <address style="font-style:normal; font-size:var(--text-sm); color:rgba(255,255,255,0.6); line-height:1.5">
              Av. 12 de Octubre 655<br />
              San Carlos de Bariloche<br />
              Río Negro, Argentina
            </address>
          </div>
          <div class="footer__contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.63a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <a href={`tel:${PHONE_CLEAN}`} class="footer__contact-link">{PHONE}</a>
          </div>
          <div class="footer__contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span style="font-size:var(--text-sm); color:rgba(255,255,255,0.6)">
              Check-in: 12:00 – 23:59<br />Check-out: hasta 10:00
            </span>
          </div>
        </div>

        <!-- Language switcher -->
        <div class="footer__lang">
          <LanguageSwitcher />
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p class="footer__closing">{t('footer.closing')}</p>
      <p class="footer__rights">© {currentYear} Argentino del Sur. {t('footer.rights')}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-blue-deep);
    color: rgba(255,255,255,0.7);
    position: relative;
    padding-top: 0;
  }

  /* Wave */
  .footer__wave {
    color: var(--color-blue-deep);
    margin-top: -1px;
    line-height: 0;
  }
  .footer__wave svg {
    width: 100%;
    height: 60px;
    display: block;
  }

  .footer .container {
    padding-top: 3rem;
    padding-bottom: 2rem;
  }

  /* Grid */
  .footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 2rem;
  }

  /* Brand */
  .footer__logo {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-bottom: 1rem;
    text-decoration: none;
  }
  .footer__logo-main {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-white);
    letter-spacing: 0.01em;
    line-height: 1;
  }
  .footer__logo-sub {
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    line-height: 1.65;
    color: rgba(255,255,255,0.55);
    margin-bottom: 1rem;
    max-width: 28ch;
  }

  .footer__rating {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.25rem;
  }
  .footer__rating-stars {
    color: var(--color-gold-light);
    font-size: 0.9rem;
    letter-spacing: 2px;
  }
  .footer__rating-text {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.45);
  }

  .footer__chips {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    font-weight: 500;
    color: rgba(255,255,255,0.70);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--transition-fast);
    width: fit-content;
  }
  .footer__chip:hover {
    background: rgba(255,255,255,0.14);
    color: var(--color-white);
  }
  .footer__chip--wa { color: #4ade80; border-color: rgba(74,222,128,0.25); }
  .footer__chip--wa:hover { background: rgba(37,211,102,0.15); }

  /* Navigation column */
  .footer__col-title {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1.25rem;
  }

  .footer__col nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__link {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.60);
    text-decoration: none;
    transition: color var(--transition-fast);
    padding: 0.2rem 0;
  }
  .footer__link:hover { color: var(--color-gold-light); }

  /* Contact column */
  .footer__contact-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
  }
  .footer__contact-item svg {
    flex-shrink: 0;
    color: var(--color-gold);
    margin-top: 0.125rem;
  }
  .footer__contact-link {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .footer__contact-link:hover { color: var(--color-gold-light); }

  .footer__lang {
    margin-top: 0.5rem;
  }

  /* Bottom bar */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .footer__closing {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.35);
  }
  .footer__rights {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.35);
  }

  @media (max-width: 900px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 580px) {
    .footer__grid { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; text-align: center; }
  }
</style>
