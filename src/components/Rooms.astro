---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const WHATSAPP_NUMBER = '5492944426373';
const WHATSAPP_MSG = encodeURIComponent('Hola! Quiero consultar disponibilidad y tarifas en el hotel Argentino del Sur.');

const rooms = [
  {
    key: 'double',
    capacity: 2,
    image: 'https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=700&q=85&auto=format',
    imageAlt: 'Habitación doble con cama matrimonial',
    badges: ['wifi', 'breakfast', 'central'],
    accent: 'blue',
  },
  {
    key: 'triple',
    capacity: 3,
    image: 'https://images.unsplash.com/photo-1566665797739-1674de7a421a?w=700&q=85&auto=format',
    imageAlt: 'Habitación triple con tres camas',
    badges: ['wifi', 'breakfast', 'kids'],
    accent: 'gold',
  },
  {
    key: 'family',
    capacity: 4,
    image: 'https://images.unsplash.com/photo-1587985064135-0366536eab42?w=700&q=85&auto=format',
    imageAlt: 'Habitación familiar amplia',
    badges: ['wifi', 'breakfast', 'kids', 'central'],
    accent: 'forest',
  },
  {
    key: 'single',
    capacity: 1,
    image: 'https://images.unsplash.com/photo-1623625434462-e5e42318ae49?w=700&q=85&auto=format',
    imageAlt: 'Habitación simple individual',
    badges: ['wifi', 'breakfast'],
    accent: 'blue',
  },
];
---

<section class="section rooms bg-stone" id="habitaciones" aria-labelledby="rooms-title">
  <div class="container">
    <div class="section-header centered">
      <span class="section-badge reveal">{t('rooms.badge')}</span>
      <h2 class="section-title reveal reveal-delay-1" id="rooms-title">
        {t('rooms.title')} <span class="highlight">{t('rooms.highlight')}</span>
      </h2>
      <p class="section-subtitle reveal reveal-delay-2">{t('rooms.subtitle')}</p>
    </div>

    <div class="rooms__grid">
      {rooms.map((room, i) => (
        <article class={`room-card card reveal reveal-delay-${(i % 3) + 1}`} aria-labelledby={`room-${room.key}-title`}>
          <!-- Image -->
          <div class="room-card__image img-wrapper">
            <img
              src={room.image}
              alt={room.imageAlt}
              loading="lazy"
              decoding="async"
            />
            <!-- Capacity badge -->
            <div class="room-card__capacity">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <span>{t('rooms.capacity')}: {room.capacity} {t('rooms.persons')}</span>
            </div>
          </div>

          <!-- Content -->
          <div class="room-card__body">
            <h3 class="room-card__name" id={`room-${room.key}-title`}>
              {t(`rooms.${room.key}.name` as any)}
            </h3>
            <p class="room-card__desc">
              {t(`rooms.${room.key}.desc` as any)}
            </p>

            <!-- Badges -->
            <div class="room-card__badges">
              {room.badges.map(b => (
                <span class="room-card__badge">{t(`rooms.badge.${b}` as any)}</span>
              ))}
            </div>

            <a
              href={`https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MSG}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline room-card__cta"
              aria-label={`${t('rooms.cta')} — ${t(`rooms.${room.key}.name` as any)}`}
            >
              {t('rooms.cta')}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .rooms__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  /* ── Room Card ── */
  .room-card {
    display: flex;
    flex-direction: column;
  }

  .room-card__image {
    aspect-ratio: 3/2;
    overflow: hidden;
  }
  .room-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .room-card:hover .room-card__image img {
    transform: scale(1.06);
  }

  .room-card__capacity {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-xs);
    font-weight: 600;
    color: white;
    background: rgba(13,27,42,0.75);
    backdrop-filter: blur(8px);
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255,255,255,0.15);
  }

  .room-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.375rem;
    gap: 0.75rem;
  }

  .room-card__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-blue-deep);
    line-height: 1.2;
  }

  .room-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.65;
    flex: 1;
  }

  .room-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .room-card__badge {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-blue-mid);
    background: rgba(37,99,168,0.08);
    border: 1px solid rgba(37,99,168,0.15);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
  }

  .room-card__cta {
    font-size: var(--text-xs);
    padding: 0.7rem 1.25rem;
    margin-top: auto;
    width: 100%;
    justify-content: center;
    gap: 0.5rem;
  }

  @media (max-width: 1100px) {
    .rooms__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .rooms__grid { grid-template-columns: 1fr; }
  }
</style>
