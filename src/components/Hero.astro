---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const WHATSAPP_NUMBER = '5492944426373';
const WHATSAPP_MSG = encodeURIComponent('Hola! Quiero consultar disponibilidad en el hotel Argentino del Sur.');

// Hero carousel images — Patagonia / Bariloche themed Unsplash photos
const slides = [
  {
    url: 'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=1600&q=85&auto=format',
    alt: 'Lago Nahuel Huapi con montañas nevadas al fondo',
  },
  {
    url: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1600&q=85&auto=format',
    alt: 'Montañas patagónicas con nieve',
  },
  {
    url: 'https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=1600&q=85&auto=format',
    alt: 'Interior acogedor de habitación de hotel',
  },
  {
    url: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600&q=85&auto=format',
    alt: 'Paisaje de montaña y lago en Patagonia',
  },
];
---

<section class="hero" id="inicio" aria-label="Inicio">
  <!-- Carousel -->
  <div class="hero__carousel" id="hero-carousel" aria-hidden="true">
    {slides.map((slide, i) => (
      <div class={`hero__slide ${i === 0 ? 'active' : ''}`} data-index={i}>
        <img
          src={slide.url}
          alt={slide.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={i === 0 ? 'high' : 'auto'}
        />
      </div>
    ))}

    <!-- Overlay gradient -->
    <div class="hero__overlay"></div>
  </div>

  <!-- Content -->
  <div class="hero__content container">
    <div class="hero__text">
      <!-- Badge -->
      <span class="hero__badge reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        {t('hero.badge')}
      </span>

      <!-- Title -->
      <h1 class="hero__title reveal reveal-delay-1">
        {t('hero.title')}
        <br />
        <em class="hero__title-em">{t('hero.highlight')}</em>
      </h1>

      <!-- Subtitle -->
      <p class="hero__subtitle reveal reveal-delay-2">{t('hero.subtitle')}</p>

      <!-- CTAs -->
      <div class="hero__ctas reveal reveal-delay-3">
        <a
          href={`https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MSG}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary hero__cta-main"
          aria-label={t('hero.cta1')}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {t('hero.cta1')}
        </a>
        <a href="#habitaciones" class="btn btn-secondary">
          {t('hero.cta2')}
        </a>
      </div>

      <!-- Info chips -->
      <div class="hero__chips reveal reveal-delay-4">
        <span class="chip">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          {t('hero.chip.location')}
        </span>
        <span class="chip">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {t('hero.chip.rating')}
        </span>
        <span class="chip">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          {t('hero.chip.breakfast')}
        </span>
        <span class="chip">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
          {t('hero.chip.wifi')}
        </span>
      </div>
    </div>
  </div>

  <!-- Carousel controls -->
  <div class="hero__controls" aria-label="Controles del carrusel">
    <button class="hero__arrow hero__arrow--prev" id="hero-prev" aria-label="Imagen anterior">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <div class="hero__dots" id="hero-dots" role="tablist">
      {slides.map((_, i) => (
        <button
          class={`hero__dot ${i === 0 ? 'active' : ''}`}
          data-index={i}
          aria-label={`Slide ${i + 1}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        ></button>
      ))}
    </div>
    <button class="hero__arrow hero__arrow--next" id="hero-next" aria-label="Siguiente imagen">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ── Carousel ── */
  .hero__carousel {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.4,0,0.2,1);
  }
  .hero__slide.active { opacity: 1; }

  .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.04);
    transition: transform 8s ease;
  }
  .hero__slide.active img { transform: scale(1); }

  /* Overlay */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(13,27,42,0.72) 0%,
      rgba(13,27,42,0.50) 50%,
      rgba(13,27,42,0.62) 100%
    );
  }

  /* ── Content ── */
  .hero__content {
    position: relative;
    z-index: 10;
    padding-top: 5rem;
    padding-bottom: 8rem;
    display: flex;
    align-items: center;
  }

  .hero__text {
    max-width: 680px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    background: rgba(201,150,58,0.18);
    border: 1px solid rgba(201,150,58,0.4);
    padding: 0.5rem 1.125rem;
    border-radius: var(--radius-full);
    margin-bottom: 1.75rem;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--color-white);
    margin-bottom: 1rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .hero__title-em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-gold-light);
  }

  .hero__subtitle {
    font-size: clamp(var(--text-sm), 1.25vw, var(--text-base));
    color: rgba(255,255,255,0.80);
    line-height: 1.65;
    margin-bottom: 2rem;
    max-width: 52ch;
    font-weight: 400;
  }

  /* CTAs */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .hero__cta-main {
    font-size: var(--text-sm);
    padding: 1rem 2rem;
    gap: 0.625rem;
  }

  /* Chips */
  .hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  /* ── Carousel controls ── */
  .hero__controls {
    position: absolute;
    bottom: 3rem;
    right: clamp(1.5rem, 4vw, 3rem);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero__arrow {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.08);
    color: white;
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .hero__arrow:hover {
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.6);
    transform: scale(1.08);
  }

  .hero__dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .hero__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.35);
    cursor: pointer;
    transition: all var(--transition-base);
    padding: 0;
  }
  .hero__dot.active {
    width: 22px;
    border-radius: 3px;
    background: var(--color-gold-light);
  }

  /* Scroll hint */
  .hero__scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    width: 1px;
    height: 3.5rem;
    background: rgba(255,255,255,0.15);
    border-radius: 2px;
    overflow: hidden;
  }
  .hero__scroll-hint span {
    display: block;
    width: 100%;
    height: 40%;
    background: var(--color-gold-light);
    border-radius: 2px;
    animation: scroll-line 2s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(300%); }
  }

  @media (max-width: 640px) {
    .hero__content { padding-bottom: 10rem; }
    .hero__controls { bottom: 1.5rem; right: 1rem; }
    .hero__scroll-hint { display: none; }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.hero__slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.hero__dot');
  const prevBtn = document.getElementById('hero-prev')!;
  const nextBtn = document.getElementById('hero-next')!;

  let current = 0;
  let autoplay: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    dots[current].setAttribute('aria-selected', 'false');

    current = (index + slides.length) % slides.length;

    slides[current].classList.add('active');
    dots[current].classList.add('active');
    dots[current].setAttribute('aria-selected', 'true');
  }

  function startAutoplay() {
    autoplay = setInterval(() => goTo(current + 1), 5500);
  }
  function resetAutoplay() {
    clearInterval(autoplay);
    startAutoplay();
  }

  prevBtn.addEventListener('click', () => { goTo(current - 1); resetAutoplay(); });
  nextBtn.addEventListener('click', () => { goTo(current + 1); resetAutoplay(); });
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { goTo(i); resetAutoplay(); });
  });

  startAutoplay();
</script>
