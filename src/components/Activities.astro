---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const activities = [
  {
    id: 1,
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=700&q=85&auto=format',
    imageAlt: lang === 'pt' ? 'Catedral de Bariloche, Argentina' : 'Catedral de Bariloche, Argentina',
    category: lang === 'pt' ? 'Patrimônio' : 'Patrimonio',
  },
  {
    id: 2,
    image: 'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=700&q=85&auto=format',
    imageAlt: lang === 'pt' ? 'Lago Nahuel Huapi com montanhas' : 'Lago Nahuel Huapi con montañas',
    category: lang === 'pt' ? 'Natureza' : 'Naturaleza',
  },
  {
    id: 3,
    image: 'https://images.unsplash.com/photo-1519659528534-7fd733a832a0?w=700&q=85&auto=format',
    imageAlt: lang === 'pt' ? 'Centro cívico de Bariloche' : 'Centro cívico de Bariloche',
    category: lang === 'pt' ? 'Cidade' : 'Ciudad',
  },
  {
    id: 4,
    image: 'https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=700&q=85&auto=format',
    imageAlt: lang === 'pt' ? 'Chocolates artesanais de Bariloche' : 'Chocolates artesanales de Bariloche',
    category: lang === 'pt' ? 'Gastronomia' : 'Gastronomía',
  },
  {
    id: 5,
    image: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=700&q=85&auto=format',
    imageAlt: lang === 'pt' ? 'Mirante panorâmico da Patagônia' : 'Mirador panorámico Patagonia',
    category: lang === 'pt' ? 'Paisagem' : 'Paisaje',
  },
  {
    id: 6,
    image: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=700&q=85&auto=format',
    imageAlt: lang === 'pt' ? 'Excursões pela Patagônia argentina' : 'Excursiones por la Patagonia argentina',
    category: lang === 'pt' ? 'Excursões' : 'Excursiones',
  },
];
---

<section class="section activities bg-dark" id="actividades" aria-labelledby="activities-title">
  <div class="container">
    <div class="section-header centered">
      <span class="section-badge reveal" style="color:var(--color-gold-light);background:rgba(201,150,58,0.15);border-color:rgba(201,150,58,0.3)">
        {t('activities.badge')}
      </span>
      <h2 class="section-title text-white reveal reveal-delay-1" id="activities-title">
        {t('activities.title')} <em class="highlight" style="color:var(--color-gold-light)">{t('activities.highlight')}</em>
      </h2>
      <p class="section-subtitle reveal reveal-delay-2" style="color:rgba(255,255,255,0.65)">
        {t('activities.subtitle')}
      </p>
    </div>

    <div class="activities__grid">
      {activities.map((act, i) => (
        <article
          class={`activity-card reveal reveal-delay-${(i % 3) + 1}`}
          aria-labelledby={`act-${act.id}-title`}
        >
          <div class="activity-card__image img-wrapper">
            <img
              src={act.image}
              alt={act.imageAlt}
              loading="lazy"
              decoding="async"
            />
            <div class="activity-card__overlay"></div>
            <span class="activity-card__category">{act.category}</span>
          </div>

          <div class="activity-card__body">
            <h3 class="activity-card__title" id={`act-${act.id}-title`}>
              {t(`activities.${act.id}.name` as any)}
            </h3>
            <p class="activity-card__desc">
              {t(`activities.${act.id}.desc` as any)}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .activities {
    position: relative;
    overflow: hidden;
  }

  /* Subtle texture overlay */
  .activities::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  /* Deep gradient at top */
  .activities::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(180deg, rgba(13,27,42,0) 0%, rgba(27,58,92,0.08) 100%);
    pointer-events: none;
  }

  .activities .section-title { color: var(--color-white); }

  /* ── Grid ── */
  .activities__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* ── Activity Card ── */
  .activity-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    transition: all var(--transition-base);
    cursor: default;
  }

  .activity-card:hover {
    transform: translateY(-6px);
    border-color: rgba(201,150,58,0.3);
    box-shadow: 0 24px 60px rgba(0,0,0,0.45);
  }

  .activity-card__image {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .activity-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .activity-card:hover .activity-card__image img {
    transform: scale(1.07);
  }

  .activity-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13,27,42,0.7) 0%, transparent 60%);
    z-index: 1;
  }

  .activity-card__category {
    position: absolute;
    top: 0.875rem;
    left: 0.875rem;
    z-index: 2;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    background: rgba(13,27,42,0.7);
    border: 1px solid rgba(201,150,58,0.3);
    backdrop-filter: blur(6px);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
  }

  /* Body */
  .activity-card__body {
    padding: 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .activity-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-white);
    line-height: 1.25;
  }

  .activity-card__desc {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.60);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .activities__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .activities__grid { grid-template-columns: 1fr; }
  }
</style>
