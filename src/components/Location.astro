---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const MAPS_EMBED = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2997.5!2d-71.3054!3d-41.1335!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x961a79f2d73f43bf%3A0x3f5be4a64b75e898!2sHotel%20Argentino%20del%20Sur!5e0!3m2!1ses!2sar!4v1714500000000!5m2!1ses!2sar';
const MAPS_URL = 'https://maps.google.com/?q=Hotel+Argentino+del+Sur,+Av.+12+de+Octubre+655,+Bariloche';

const nearby = [
  { nameKey: 'location.nearby.1', distKey: 'location.nearby.1.dist', icon: '⛪' },
  { nameKey: 'location.nearby.2', distKey: 'location.nearby.2.dist', icon: '🏔️' },
  { nameKey: 'location.nearby.3', distKey: 'location.nearby.3.dist', icon: '🏛️' },
  { nameKey: 'location.nearby.4', distKey: 'location.nearby.4.dist', icon: '🍫' },
  { nameKey: 'location.nearby.5', distKey: 'location.nearby.5.dist', icon: '🎭' },
];
---

<section class="section location bg-stone" id="ubicacion" aria-labelledby="location-title">
  <div class="container">
    <div class="location__grid">
      <div class="location__info">
        <span class="section-badge reveal">{t('location.badge')}</span>
        <h2 class="section-title reveal reveal-delay-1" id="location-title">
          {t('location.title')} <br /><span class="highlight">{t('location.highlight')}</span>
        </h2>
        <div class="divider reveal reveal-delay-1"></div>
        <p class="loc__sub reveal reveal-delay-2">{t('location.subtitle')}</p>

        <div class="loc__address reveal reveal-delay-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <address style="font-style:normal">{t('location.address')}</address>
        </div>

        <div class="loc__nearby reveal reveal-delay-3">
          <p class="loc__nearby-heading">{t('location.nearby.title')}</p>
          <ul role="list">
            {nearby.map(p => (
              <li class="loc__nearby-item">
                <span aria-hidden="true">{p.icon}</span>
                <span class="loc__nearby-name">{t(p.nameKey as any)}</span>
                <span class="loc__nearby-dist">{t(p.distKey as any)}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="loc__howto reveal reveal-delay-3">
          <strong>{t('location.howtoget')}</strong>
          <p>{t('location.howtoget.desc')}</p>
        </div>

        <a href={MAPS_URL} target="_blank" rel="noopener noreferrer"
           class="btn btn-primary reveal reveal-delay-4" style="gap:.6rem">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
          {t('location.maps.cta')}
        </a>
      </div>

      <div class="location__map reveal reveal-delay-2">
        <div class="loc__map-wrap">
          <iframe src={MAPS_EMBED} title="Ubicación Hotel Argentino del Sur" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade"></iframe>
          <div class="loc__map-card glass-dark">
            <strong>Argentino del Sur</strong>
            <p>Av. 12 de Octubre 655, Bariloche</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.location__grid { display:grid; grid-template-columns:1fr 1.1fr; gap:clamp(3rem,6vw,5rem); align-items:start; }
.loc__sub { font-size:var(--text-lg); color:var(--color-text-secondary); line-height:1.7; margin-bottom:1.75rem; }
.loc__address { display:flex; align-items:flex-start; gap:.875rem; background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--radius-md); padding:1rem 1.25rem; margin-bottom:1.75rem; box-shadow:var(--shadow-sm); font-size:var(--text-sm); color:var(--color-text-secondary); }
.loc__address svg { flex-shrink:0; color:var(--color-gold); margin-top:.125rem; }
.loc__nearby { margin-bottom:1.75rem; }
.loc__nearby-heading { font-size:var(--text-sm); font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:.875rem; }
.loc__nearby ul { list-style:none; display:flex; flex-direction:column; gap:.375rem; }
.loc__nearby-item { display:flex; align-items:center; gap:.75rem; font-size:var(--text-sm); padding:.5rem 0; border-bottom:1px solid var(--color-border); }
.loc__nearby-item:last-child { border-bottom:none; }
.loc__nearby-name { flex:1; font-weight:500; color:var(--color-text-primary); }
.loc__nearby-dist { font-size:var(--text-xs); color:var(--color-text-muted); background:var(--color-stone-100); border:1px solid var(--color-border); padding:.2rem .625rem; border-radius:var(--radius-full); white-space:nowrap; }
.loc__howto { background:var(--color-white); border-left:3px solid var(--color-gold); padding:1rem 1.25rem; border-radius:0 var(--radius-md) var(--radius-md) 0; margin-bottom:1.75rem; box-shadow:var(--shadow-sm); }
.loc__howto strong { display:block; font-size:var(--text-sm); font-weight:700; color:var(--color-blue-deep); margin-bottom:.375rem; }
.loc__howto p { font-size:var(--text-sm); color:var(--color-text-secondary); line-height:1.65; }
.loc__map-wrap { position:relative; border-radius:var(--radius-xl); overflow:hidden; box-shadow:var(--shadow-xl); border:1px solid var(--color-border); }
.loc__map-wrap iframe { width:100%; height:500px; border:none; display:block; }
.loc__map-card { position:absolute; bottom:1.25rem; left:1.25rem; right:1.25rem; padding:1rem 1.25rem; border-radius:var(--radius-md); color:var(--color-white); }
.loc__map-card strong { display:block; font-size:var(--text-sm); color:var(--color-gold-light); margin-bottom:.25rem; }
.loc__map-card p { font-size:var(--text-xs); color:rgba(255,255,255,.65); }
@media(max-width:900px){ .location__grid{grid-template-columns:1fr;} .loc__map-wrap iframe{height:340px;} }
</style>
