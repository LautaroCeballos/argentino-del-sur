---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const WHATSAPP_NUMBER = '5492944426373';
const WHATSAPP_MSG = encodeURIComponent('Hola! Quiero consultar disponibilidad y tarifas en el hotel Argentino del Sur.');
const PHONE = '+54 294 442-6373';
const PHONE_CLEAN = '+542944426373';
---

<section class="section contact" id="contacto" aria-labelledby="contact-title">
  <div class="container">
    <div class="contact__grid">

      <!-- Left: info -->
      <div class="contact__info">
        <span class="section-badge reveal">{t('contact.badge')}</span>
        <h2 class="section-title reveal reveal-delay-1" id="contact-title">
          {t('contact.title')} <br />
          <span class="highlight">{t('contact.highlight')}</span>
        </h2>
        <div class="divider reveal reveal-delay-1"></div>
        <p class="contact__subtitle reveal reveal-delay-2">{t('contact.subtitle')}</p>

        <!-- Contact methods -->
        <div class="contact__methods reveal reveal-delay-2">
          <a href={`https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MSG}`}
             target="_blank" rel="noopener noreferrer"
             class="contact__method contact__method--wa">
            <div class="contact__method-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="contact__method-body">
              <span class="contact__method-label">WhatsApp</span>
              <span class="contact__method-value">{t('contact.whatsapp.cta')}</span>
            </div>
            <svg class="contact__method-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>

          <a href={`tel:${PHONE_CLEAN}`} class="contact__method">
            <div class="contact__method-icon contact__method-icon--blue">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.63a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div class="contact__method-body">
              <span class="contact__method-label">{lang === 'pt' ? 'Telefone' : 'Teléfono'}</span>
              <span class="contact__method-value">{PHONE}</span>
            </div>
          </a>

          <div class="contact__method contact__method--info">
            <div class="contact__method-icon contact__method-icon--gold">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="contact__method-body">
              <span class="contact__method-label">{lang === 'pt' ? 'Check-in / Check-out' : 'Check-in / Check-out'}</span>
              <span class="contact__method-value">{t('contact.checkin.label')}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact__form-wrap reveal reveal-delay-2">
        <div class="contact__form-card">
          <form class="contact__form" id="contact-form" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="cf-name">{t('contact.form.name')} *</label>
                <input class="form-input" type="text" id="cf-name" name="name" required
                  placeholder={lang === 'pt' ? 'Seu nome' : 'Tu nombre'} autocomplete="name" />
              </div>
              <div class="form-group">
                <label class="form-label" for="cf-email">{t('contact.form.email')} *</label>
                <input class="form-input" type="email" id="cf-email" name="email" required
                  placeholder={lang === 'pt' ? 'seu@email.com' : 'tu@email.com'} autocomplete="email" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="cf-checkin">{t('contact.form.checkin')}</label>
                <input class="form-input" type="date" id="cf-checkin" name="checkin" />
              </div>
              <div class="form-group">
                <label class="form-label" for="cf-checkout">{t('contact.form.checkout')}</label>
                <input class="form-input" type="date" id="cf-checkout" name="checkout" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="cf-guests">{t('contact.form.guests')}</label>
              <input class="form-input" type="number" id="cf-guests" name="guests" min="1" max="10"
                placeholder={lang === 'pt' ? 'Número de hóspedes' : 'Número de huéspedes'} />
            </div>

            <div class="form-group">
              <label class="form-label" for="cf-message">{t('contact.form.message')}</label>
              <textarea class="form-input" id="cf-message" name="message" rows="4"
                placeholder={lang === 'pt' ? 'Escreva sua consulta...' : 'Escribe tu consulta...'}></textarea>
            </div>

            <button type="submit" class="btn btn-primary contact__submit">
              {t('contact.form.submit')}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>

            <p class="contact__trust">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {t('contact.form.trust')}
            </p>
          </form>

          <!-- Success message -->
          <div class="contact__success" id="contact-success" aria-live="polite" hidden>
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <h3>{lang === 'pt' ? 'Mensagem enviada!' : '¡Mensaje enviado!'}</h3>
            <p>{lang === 'pt' ? 'Entraremos em contato em breve.' : 'Te contactaremos a la brevedad.'}</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.contact { background: linear-gradient(160deg, var(--color-white) 0%, var(--color-stone-100) 100%); }
.contact__grid { display:grid; grid-template-columns:1fr 1.15fr; gap:clamp(3rem,6vw,5rem); align-items:start; }
.contact__subtitle { font-size:var(--text-lg); color:var(--color-text-secondary); line-height:1.7; margin-bottom:2rem; }

/* Methods */
.contact__methods { display:flex; flex-direction:column; gap:1rem; }
.contact__method {
  display:flex; align-items:center; gap:1rem;
  background:var(--color-white); border:1px solid var(--color-border);
  border-radius:var(--radius-lg); padding:1.125rem 1.25rem;
  text-decoration:none; transition:all var(--transition-base);
  box-shadow:var(--shadow-sm);
}
.contact__method:hover { border-color:var(--color-gold); transform:translateX(4px); box-shadow:var(--shadow-md); }
.contact__method--wa { border-color:rgba(37,211,102,0.3); }
.contact__method--wa:hover { border-color:#25D366; }
.contact__method--info { cursor:default; }
.contact__method--info:hover { transform:none; }

.contact__method-icon {
  width:3rem; height:3rem; flex-shrink:0; border-radius:var(--radius-md);
  background:#25D366; color:white; display:flex; align-items:center; justify-content:center;
}
.contact__method-icon--blue { background:var(--color-blue-mid); }
.contact__method-icon--gold { background:rgba(201,150,58,0.12); color:var(--color-gold); }

.contact__method-body { flex:1; display:flex; flex-direction:column; gap:.15rem; }
.contact__method-label { font-size:var(--text-xs); font-weight:600; letter-spacing:.06em; text-transform:uppercase; color:var(--color-text-muted); }
.contact__method-value { font-size:var(--text-sm); font-weight:600; color:var(--color-text-primary); }
.contact__method-arrow { color:var(--color-text-muted); flex-shrink:0; }

/* Form card */
.contact__form-card {
  background:var(--color-white); border:1px solid var(--color-border);
  border-radius:var(--radius-xl); padding:clamp(1.5rem,4vw,2.5rem);
  box-shadow:var(--shadow-lg);
}
.contact__form { display:flex; flex-direction:column; gap:1.25rem; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.contact__submit { width:100%; justify-content:center; gap:.625rem; padding:1rem; font-size:var(--text-sm); }
.contact__trust {
  display:flex; align-items:center; gap:.5rem;
  font-size:var(--text-xs); color:var(--color-text-muted); text-align:center; justify-content:center;
}
.contact__trust svg { flex-shrink:0; color:var(--color-forest-mid); }

/* Success */
.contact__success {
  text-align:center; padding:3rem 2rem;
  display:flex; flex-direction:column; align-items:center; gap:1rem;
}
.contact__success svg { color:var(--color-forest-mid); }
.contact__success h3 { font-family:var(--font-display); font-size:var(--text-2xl); color:var(--color-blue-deep); }
.contact__success p { color:var(--color-text-secondary); }

@media(max-width:900px){ .contact__grid{grid-template-columns:1fr;} }
@media(max-width:540px){ .form-row{grid-template-columns:1fr;} }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '...';

    // Simulate async (replace with real endpoint or Netlify forms)
    await new Promise(r => setTimeout(r, 900));

    form.hidden = true;
    if (success) success.hidden = false;
  });
</script>
