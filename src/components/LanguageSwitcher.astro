---
import { languages } from '../i18n/ui';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const flags: Record<string, string> = { es: '🇦🇷', pt: '🇧🇷' };
const labels: Record<string, string> = { es: 'ES', pt: 'PT' };
---

<div class="lang-switcher" role="navigation" aria-label="Selector de idioma">
  <button class="lang-btn" id="lang-toggle" aria-expanded="false" aria-haspopup="true">
    <span class="lang-flag">{flags[lang]}</span>
    <span class="lang-label">{labels[lang]}</span>
    <svg class="lang-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </button>

  <div class="lang-dropdown" id="lang-dropdown" role="menu" aria-hidden="true">
    {Object.entries(languages).map(([code, label]) => (
      <a
        href={translatePath('/', code)}
        class={`lang-option ${lang === code ? 'active' : ''}`}
        role="menuitem"
        hreflang={code}
      >
        <span>{flags[code]}</span>
        <span>{label}</span>
        {lang === code && (
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        )}
      </a>
    ))}
  </div>
</div>

<style>
  .lang-switcher {
    position: relative;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.22);
    color: rgba(255,255,255,0.90);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-family: var(--font-body);
  }
  .lang-btn:hover {
    background: rgba(255,255,255,0.20);
    border-color: rgba(255,255,255,0.4);
  }

  /* When header is scrolled, adapt colors */
  :global(.header.scrolled) .lang-btn {
    background: var(--color-stone-100);
    border-color: var(--color-border);
    color: var(--color-text-secondary);
  }
  :global(.header.scrolled) .lang-btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .lang-flag { font-size: 1rem; line-height: 1; }
  .lang-label { font-size: var(--text-xs); }

  .lang-chevron {
    transition: transform var(--transition-fast);
  }
  .lang-btn[aria-expanded="true"] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    padding: 0.375rem;
    min-width: 9rem;
    display: none;
    flex-direction: column;
    gap: 0.125rem;
    z-index: 200;
    animation: dropdown-in 0.18s ease;
  }
  .lang-dropdown.open {
    display: flex;
  }

  @keyframes dropdown-in {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: background var(--transition-fast), color var(--transition-fast);
    text-decoration: none;
  }
  .lang-option:hover {
    background: var(--color-stone-100);
    color: var(--color-text-primary);
  }
  .lang-option.active {
    color: var(--color-gold);
    background: rgba(201,150,58,0.08);
    font-weight: 600;
  }
  .lang-option svg { margin-left: auto; color: var(--color-gold); }
</style>

<script>
  const toggle = document.getElementById('lang-toggle')!;
  const dropdown = document.getElementById('lang-dropdown')!;

  toggle.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = dropdown.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
    dropdown.setAttribute('aria-hidden', String(!open));
  });

  document.addEventListener('click', () => {
    dropdown.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
    dropdown.setAttribute('aria-hidden', 'true');
  });
</script>
